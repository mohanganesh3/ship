% ============================================================
\section{Pipeline Deep Dive: Stage by Stage}
% ============================================================

\begin{frame}{Stage 1 --- Continued Pre-Training (CPT): Seeds the Weights}
\begin{columns}[T]
\column{0.50\textwidth}
\begin{block}{What CPT Does (Next-Token Prediction)}
CPT runs next-token prediction on raw maritime text. No labels, no Q\&A. Teaches:
\begin{itemize}
  \item Maritime \textbf{vocabulary} and terminology
  \item Domain \textbf{conceptual structure} (SOLAS + fire safety cluster together)
  \item Semantic proximity of related concepts
  \item \textbf{Distributional patterns} of technical writing
\end{itemize}
\textbf{Analogy:} Student reads all textbooks cover-to-cover --- understands territory but hasn't been tested.
\end{block}

\begin{warningblock}{CPT Alone = Insufficient}
\scriptsize
Domain QA accuracy with CPT alone: \textbf{3/10}. Produces maritime-flavored \textbf{text generator}, not a chatbot.
\end{warningblock}

\column{0.47\textwidth}
\begin{successblock}{QLoRA Implementation Details}
\scriptsize
\textbf{Base model:} Qwen3-4B, 36T pretrain tokens\\
\textbf{Rank:} r=32 for CPT (r=64 optimal; r=32 fits T4 free)\\
\textbf{Alpha:} 64. Use \texttt{use\_rslora=True} (free improvement for r$>$16)\\
\textbf{Targets:} q, k, v, o, \textbf{gate\_proj, up\_proj, down\_proj} + embeddings\\
\textbf{Epochs:} 2--3 on corpus\\
\textbf{LR:} 5e-5 with cosine schedule\\[4pt]
\textbf{Critical:} Must target \textbf{MLP layers} (gate/up/down) --- ROME paper shows facts stored in MLP, layers 15--25 of 32-layer transformer.\\[4pt]
\textbf{NEFTune:} Add uniform noise to embedding during training $\to$ +35\% accuracy (arXiv:2310.05914). Free 1-line addition.
\end{successblock}

\begin{block}{QLoRA vs Full FT}
\scriptsize
QLoRA r=64 = \textbf{88\%} of Full FT knowledge absorption.\\
Full FT on A100: 7--12\% improvement, \$10--40 extra.\\
\textbf{Main bottleneck is DATA VOLUME, not QLoRA gap.}
\end{block}

\end{columns}
\end{frame}

\begin{frame}{Stage 2 --- Synthetic SFT: Crystallizing the Knowledge}
\begin{columns}[T]
\column{0.50\textwidth}
\begin{block}{Synthetic Q\&A Generation Strategy}
\textbf{Teacher model} (GPT-4o or Qwen3-32B) generates diverse Q\&A:
\vspace{4pt}
\begin{center}
\begin{tabular}{@{}lr@{}}
\toprule
\textbf{Q\&A Type} & \textbf{Target \%}\\
\midrule
Factual recall & 40\%\\
Procedural/how-to & 25\%\\
Troubleshooting/diagnosis & 15\%\\
Safety-critical scenarios & 10\%\\
Regulatory compliance & 5\%\\
Graceful refusals (OOD) & 5\%\\
\bottomrule
\end{tabular}
\end{center}
\vspace{4pt}
\textbf{Memorization technique:} 5--10 Q\&A variations per key fact ensures reliable recall.
\end{block}

\column{0.47\textwidth}
\begin{block}{Key Research Backing}
\scriptsize
\textbf{DEITA} (arXiv:2312.15685): 6K carefully selected samples = 60K+ generic.\\[4pt]
\textbf{LAB taxonomy} (arXiv:2403.01081): Guided synthetic data ensures complete domain coverage.\\[4pt]
\textbf{Corrected myth --- Phi-1:} Success was \textbf{pretraining on synthetic textbooks}, not SFT alone.\\[4pt]
\textbf{Evol-Instruct:} Each Q\&A spawns 2--3 harder variants. Target: 20K--50K pairs.
\end{block}

\begin{successblock}{Expected Accuracy After SFT}
\scriptsize
\begin{tabular}{@{}lr@{}}
Conceptual questions & 85--90\%\\
Procedural how-to & 75--85\%\\
Troubleshooting & 60--70\%\\
Exact regulation numbers & 35--55\%\\
Cross-regulation reasoning & 25--45\%\\
\textbf{Weighted average} & \textbf{65--75\%}\\
\end{tabular}
\end{successblock}
\end{columns}
\end{frame}

\begin{frame}{Stages 3 \& 4 --- DPO Alignment, Model Soup, Quantization}
\begin{columns}[T]
\column{0.48\textwidth}

\begin{block}{Stage 3: DPO Safety Alignment}
\textbf{Direct Preference Optimization} (arXiv:2305.18290) prevents:
\begin{itemize}
  \item Hallucination on out-of-domain questions
  \item Unsafe responses to emergency queries
  \item Overconfident wrong answers on exact numbers
\end{itemize}
Teaches the model: \textit{``I'm not certain, please verify in [source].''}\\[4pt]
\textbf{Parameters:} $\beta$ = 0.01 across all runs.\\
\textbf{Data:} 1,000--5,000 preference pairs.\\
\textbf{Time:} 2--4 GPU hours on T4.
\end{block}

\begin{warningblock}{DPO Failure Mode (Critical)}
\scriptsize
Smaug/DPOP (arXiv:2402.13228): Standard DPO can \textbf{reduce} likelihood of preferred responses.\\
\textbf{Fix:} Use KTO variant for crew feedback loop (thumbs up/down), or GRPO (DeepSeek-R1 method).
\end{warningblock}

\column{0.48\textwidth}

\begin{block}{Stage 4a: Model Soup (Merging)}
\textbf{SmolLM3 recipe:}\\
$\quad$ 0.9 $\times$ DPO checkpoint $+$ 0.1 $\times$ pre-DPO checkpoint\\[4pt]
Recovers long-context (RULER) performance degraded by DPO, while keeping alignment.\\[4pt]
\textbf{Tool:} MergeKit (arcee-ai/mergekit) --- CPU-only, free, minutes.
\end{block}

\vspace{4pt}
\begin{successblock}{Stage 4b: Q4\_K\_M GGUF}
\scriptsize
\textbf{Format:} Q4\_K\_M = 4-bit K-quant with mixed precision layers.\\
\textbf{Qwen3-4B Q4\_K\_M:} $\sim$\textbf{2.5 GB} disk, $\sim$\textbf{4.5 GB} RAM.\\
\textbf{Speed:} 5--15 tok/s on modern laptop CPU.\\[4pt]
\textbf{Q4 = Goldilocks zone:} Below Q4, accuracy drops faster than size.\\
\textbf{AWQ insight:} Protect salient weight channels for maritime terminology.\\
\textbf{Run via:} llama.cpp, Ollama, or llamafile.
\end{successblock}

\end{columns}
\end{frame}

% ============================================================
\section{QLoRA: Knowledge Mechanics}
% ============================================================

\begin{frame}{QLoRA Knowledge Injection: Architecture \& Expected Accuracy}
\begin{columns}[T]
\column{0.50\textwidth}
\begin{block}{Qwen3-4B Architecture}
\begin{center}
\begin{tabular}{@{}lr@{}}
\toprule
Total parameters & 4.0B\\
Hidden dimension & 2,560\\
FFN dimension & 10,880\\
Transformer layers & 36\\
Attention heads (Q) & 32\\
Attention heads (KV) & 8 (GQA)\\
Vocabulary size & 151,936\\
Context window & 128K\\
\midrule
LoRA r=32 trainable params & 65.6M\\
+ Embeddings (Unsloth) & +780M\\
\midrule
\textbf{Fact storage:} MLP layers & 15--25\\
\bottomrule
\end{tabular}
\end{center}
\end{block}

\begin{block}{Bottleneck Priority}
\scriptsize
\textbf{\#1} Data volume (42.75M is adequate, not abundant)\\
\textbf{\#2} Model size (4B param knowledge capacity)\\
\textbf{\#3} Synthetic data quality (DEITA-style)\\
\textbf{\#4} QLoRA vs Full FT gap (only 8--12\%)\\
\textbf{\#5} Q4 quantization loss ($<$3\%)\\
\textit{"More data beats switching to Full FT."}
\end{block}

