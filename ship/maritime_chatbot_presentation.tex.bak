% ---- FULL PIPELINE EXPLANATION SLIDE ----
\begin{frame}{OUR SELECTED APPROACH: The Full Pipeline Explained}
\begin{columns}[T]
\column{0.52\textwidth}
\begin{goldblock}{$\bigstar$ What We Built \& Why}
\scriptsize
\textbf{Base:} Qwen3-4B (Apache 2.0, 36T pretrain tokens, MMLU 79.9\%)\\[4pt]
\textbf{Stage 1 -- CPT (QLoRA r=32, 2--3 epochs):}\\
$\to$ Feed all 42.75M maritime tokens via next-token prediction.\\
$\to$ Embeds maritime vocabulary \& conceptual structure into weights.\\[4pt]
\textbf{Stage 2 -- Synthetic SFT (20K--50K Q\&A pairs):}\\
$\to$ Qwen3-32B teacher generates diverse procedures, facts, rules.\\
$\to$ Evol-Instruct amplification $\times$3. NEFTune noise enabled.\\
$\to$ Converts text-generator into a chatbot that answers questions.\\[4pt]
\textbf{Stage 3 -- DPO alignment ($\beta$=0.01, 1K--5K pairs):}\\
$\to$ Teaches graceful refusals on out-of-domain questions.\\
$\to$ Reduces overconfident wrong answers on exact regulation numbers.\\[4pt]
\textbf{Stage 4 -- Model Soup + Q4\_K\_M GGUF:}\\
$\to$ Merge: 0.9$\times$DPO + 0.1$\times$pre-DPO (recovers long-context).\\
$\to$ Quantize to Q4\_K\_M: 2.5 GB file, 4.5 GB RAM, runs on any PC.\\
$\to$ Deploy via Ollama. Zero internet needed after setup.
\end{goldblock}

\column{0.45\textwidth}
\begin{block}{Why This Exact Combination?}
\scriptsize
\begin{tabular}{@{}lc@{}}
\toprule
\textbf{What it provides} & \textbf{Stage}\\
\midrule
Domain vocabulary in weights & CPT\\
Conceptual knowledge structure & CPT\\
Question-answering ability & SFT\\
Procedural recall (how-to) & SFT\\
Safety refusals on unknowns & DPO\\
Calibrated uncertainty & DPO\\
Long-context recovery & Soup\\
Edge-device file size & GGUF\\
Zero-internet operation & Ollama\\
\bottomrule
\end{tabular}
\end{block}

\vspace{4pt}
\begin{successblock}{The Key Point}
\scriptsize
\textbf{CPT alone} = maritime text generator (score 3/10 QA).\\
\textbf{SFT alone} = good chatbot, lacks deep domain facts.\\
\textbf{CPT + SFT} = synergy --- knowledge + accessibility.\\
\textbf{DPO + Soup + GGUF} = production-ready on ship hardware.\\[2pt]
\textbf{No other single-stage approach achieves this.}\\
This is why the Full Pipeline scores \textbf{73/100} vs 71 (SFT only) and 61 (CPT only).
\end{successblock}
\end{columns}
\end{frame}

