\section{Dataset Gaps \& Deployment}
% ============================================================

\begin{frame}{Dataset Coverage Gaps: What We're Missing}
\begin{columns}[T]
\column{0.48\textwidth}

\begin{successblock}{Strong Coverage (Theory)}
\scriptsize
\begin{itemize}
  \item Marine diesel engines (4-stroke, 2-stroke, thermodynamics)
  \item Naval architecture (stability, hydrostatics, trim)
  \item MARPOL Annexes I, II, IV, V, VI (core text)
  \item SOLAS (fire, LSA, stability fundamentals)
  \item STCW watchkeeping hours and rest requirements
  \item Accident reports and case studies (MAIB, NTSB)
  \item General safety culture and SMS
\end{itemize}
\textbf{Verdict: Textbook-heavy, theory-strong.}
\end{successblock}

\column{0.48\textwidth}

\begin{dangerblock}{Critical Gaps (40--50\% of daily ops)}
\scriptsize
\textcolor{danger}{\textbf{CRITICAL}} Cargo ops: ISGOTT (tanker), IBC Code (chem), IMSBC Code (bulk), IMDG Code (container), IGC Code (LNG/LPG)\\[2pt]
\textcolor{danger}{\textbf{CRITICAL}} Auxiliary machinery: OWS, FWG, sewage treatment, incinerators, fuel purifiers\\[2pt]
\textcolor{danger}{\textbf{CRITICAL}} GMDSS: MF/HF/VHF distress, DSC controller, EPIRB\\[2pt]
\textcolor{danger}{\textbf{CRITICAL}} ECDIS: passage planning, alarms (mandatory SOLAS vessels)\\[2pt]
\textcolor{warning}{\textbf{SEVERE}} PSC inspection prep, bunkering, Permit to Work\\[2pt]
\textbf{Note:} OWS = \#1 PSC detention item globally.
\end{dangerblock}

\end{columns}

\vspace{4pt}
\begin{block}{Priority Acquisition Plan (High Level)}
\scriptsize
\textbf{Immediate (free):} IMO circulars (imo.org), MAIB reports, USCG safety alerts, Gard/UK P\&I guidance, OCIMF publications.\\
\textbf{Paid (high priority):} ISGOTT 6th Ed., Marine Auxiliary Machinery (McGeorge), IMO GMDSS Manual, IMSBC Code 2023.\\
\textbf{Gap closure via synthesis:} Generate OWS, FWG, GMDSS Q\&A from existing content + GPT-4o knowledge.\\
\textbf{See next slide} for the full 10/10 dataset health roadmap.
\end{block}
\end{frame}

