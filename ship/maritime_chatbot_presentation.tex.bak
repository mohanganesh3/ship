\begin{frame}{Why the Bottom 5 Fail: Key Verdicts}
\begin{columns}[T]
\column{0.48\textwidth}

\begin{dangerblock}{Reasoning Distillation --- 52/100}
\textbf{Fatal:} Mobile latency 3--7s $\to$ 20--55s (8$\times$ worse).\\
DeepSeek-R1-1.5B: 83.9\% MATH-500 --- for math, not maritime facts.\\
\textit{"Reasoning $\times$ 0 knowledge = 0 useful output"}
\end{dangerblock}

\vspace{4pt}
\begin{dangerblock}{Extreme Quantization / BitNet --- 53/100}
\textbf{Fatal:} 7B@2-bit does NOT beat 1.7B@4-bit for factual recall.\\
BiLLM: LLaMA-7B perplexity 5.47 $\to$ 29.79 at 1.08-bit.\\
No maritime production deployment. Revisit \textbf{2027--2028}.
\end{dangerblock}

\vspace{4pt}
\begin{dangerblock}{Pruning / Sparsification --- 56/100}
\textbf{Fatal:} Unstructured sparsity = \textbf{ZERO speedup on ARM CPU}.\\
\textit{"Cannot preserve knowledge the model never had."}\\
Maritime content = 0.01\% of web pretraining data.
\end{dangerblock}

\column{0.48\textwidth}

\begin{warningblock}{RL Methods (DPO/PPO) --- 57/100}
KL divergence constraint \textbf{prevents} large weight changes needed for domain knowledge.\\
Smaug/DPOP (arXiv:2402.13228): DPO can \textbf{reduce} preferred response likelihood.\\
\textit{Correct role:} Phase 4 alignment only, not knowledge injection.
\end{warningblock}

\vspace{4pt}
\begin{warningblock}{Test-Time Compute (TTC) --- 57/100}
\textbf{Myth corrected:} s1 paper used \textbf{32B model}, not 1B.\\
55\% of maritime QA = pure \textbf{factual recall} --- TTC provides zero benefit.\\
Self-consistency N=5: 83--133s per query on mobile. Impractical.\\
\textit{Correct role:} Last-mile enhancement \textbf{on top of} full pipeline.
\end{warningblock}

\end{columns}
\end{frame}

\begin{frame}{Approaches 6--9: Good Individually, Better Combined}
\begin{columns}[T]
\column{0.48\textwidth}

\begin{block}{Pre-training from Scratch --- 62/100}
\scriptsize
\textbf{Best analogue:} BioMedLM (2.7B), 69\% MMLU Medical Genetics.\\
\textbf{Maritime fatal:} Only $\sim$200M tokens vs PubMed's 100B+.\\
\textbf{Cost:} \$100K--\$300K (384 H100s, 24 days for SmolLM3 3B).\\
CPT achieves \textbf{95\%} of from-scratch quality at \textbf{0.1\%} cost.\\
Annual maintenance \$100K+ per regulatory update = fatal.\\
\textit{Apply: Phi-1/SmolLM3 data quality insights to our CPT pipeline.}
\end{block}

\vspace{4pt}
\begin{block}{CPT Alone --- 61/100}
\scriptsize
\textbf{Phi-3 admission:} \textit{"Model simply does not have the capacity to store too much factual knowledge."}\\
Domain QA accuracy with CPT alone: \textbf{3/10}.\\
Produces maritime-flavored \textbf{text generator}, NOT a chatbot.\\
\textit{Correct role:} Phase 1 foundation --- required but not sufficient.
\end{block}

\column{0.48\textwidth}

\begin{block}{Model Merging --- 64/100}
\scriptsize
DARE paper: Delta redundancy \textit{"more pronounced in large-scale LMs"} --- fails harder at 1--3B.\\
Merging is \textbf{composition}, not knowledge injection.\\
\textbf{SmolLM3 recipe:} 0.9$\times$APO + 0.1$\times$mid-training checkpoint\\
$\to$ recovered RULER long-context performance.\\
\textit{Correct role:} Phase 4 model soup finishing --- free, CPU-only, MergeKit.
\end{block}

\vspace{4pt}
\begin{successblock}{SFT + Synthetic Data --- 71/100}
\scriptsize
DEITA (arXiv:2312.15685): \textbf{6K selected} = 60K+ generic datasets.\\
\textbf{Corrected myth:} Phi-1 success = PRETRAINING on synthetic textbooks, not SFT alone.\\
NEFTune (arXiv:2310.05914): +29\%$\to$64\% AlpacaEval --- free 1-line addition.\\
Full SFT (not LoRA) for domain training.\\
Cost: API \$100--500 + GPU \$5--30 = \textbf{\$150--700 total}.
\end{successblock}

\end{columns}
\end{frame}

% ============================================================
\section{The Winning Pipeline}
% ============================================================

\begin{frame}{Why CPT + SFT = 73/100: The Synergy Effect}
\begin{columns}[T]
\column{0.52\textwidth}

\begin{goldblock}{$\bigstar$ The Key Insight: Superadditive Synergy}
\begin{center}
\begin{tabular}{@{}lcc@{}}
\toprule
\textbf{Method} & \textbf{Knowledge Score} & \textbf{Chatbot?}\\
\midrule
CPT Alone & 4/10 & No\\
SFT Alone & 5/10 & Partial\\
\textbf{CPT + Synth.\ SFT} & \textbf{7/10} & \textbf{YES}\\
\bottomrule
\end{tabular}
\end{center}
\vspace{4pt}
CPT \textbf{seeds} the weight space with maritime distributional patterns. SFT \textbf{crystallizes} specific facts into retrievable Q\&A patterns. Combined: not additive --- \textbf{synergistic.}
\end{goldblock}

\vspace{6pt}
\begin{block}{SmolLM3 Proof (Open 3B Pipeline)}
\scriptsize
\textbf{Exact pipeline:} Multi-stage pretraining $\to$ SFT (Qwen3-32B teacher, 1.8B synthetic tokens) $\to$ APO alignment $\to$ Model Merge.\\
\textbf{Result:} Outperforms Llama-3.2-3B and Qwen2.5-3B on all benchmarks.\\
\textbf{Recipe:} Fully open at github.com/huggingface/smollm
\end{block}

\column{0.45\textwidth}
