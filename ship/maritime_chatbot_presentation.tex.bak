% ============================================================
\section{The Problem: Ships Need Offline AI}
% ============================================================

\begin{frame}{Why Ships Need an Offline AI Chatbot}
\begin{columns}[T]
\column{0.50\textwidth}
\begin{block}{The Operational Reality at Sea}
\begin{itemize}
  \item Ships operate \textbf{thousands of km} from shore
  \item \textbf{No reliable internet} --- satellite is costly, slow, intermittent
  \item International crews: English as 2nd/3rd language
  \item Engineers need answers \textbf{at 3 AM} on watch
  \item SOLAS, MARPOL, STCW spans \textbf{thousands of pages}
  \item Human error is the \textbf{\#1 cause} of maritime accidents
\end{itemize}
\end{block}

\begin{warningblock}{Current Situation}
Engineers carry heavy physical manuals or rely on \textbf{memory} for critical procedures. No intelligent assistant exists for \textbf{fully offline} ship use.
\end{warningblock}

\column{0.47\textwidth}
\begin{block}{Hard Constraints (Non-Negotiable)}
\begin{tabular}{@{}cl@{}}
$\times$ & \textbf{No internet} at inference time\\[3pt]
$\times$ & \textbf{No RAG} nor vector DB at sea\\[3pt]
$\times$ & \textbf{No Cloud GPU} --- ship hardware only\\[3pt]
$\times$ & \textbf{No 7B+ models} --- RAM exceeded\\[3pt]
$\checkmark$ & \textbf{1--4B parameters}, CPU-only\\[3pt]
$\checkmark$ & Under \textbf{4 GB RAM} runtime\\[3pt]
$\checkmark$ & \textbf{All knowledge in weights}\\[3pt]
$\checkmark$ & \textbf{Fully offline} post-setup\\
\end{tabular}
\end{block}

\vspace{4pt}
\begin{dangerblock}{Why No RAG? (Memory Math)}
\scriptsize
\textbf{Full RAG system RAM requirements:}\\
Embedding model (e5-large): $\sim$1.3 GB $\quad$ Vector index (FAISS): $\sim$1.5 GB\\
LLM inference (Qwen3-4B Q4): $\sim$4.5 GB\\
\textbf{Total: 7--9 GB RAM} --- ship PCs typically have 4--6 GB.\\
\textit{Plus:} always-on embedding server, index maintenance, update pipeline.\\[2pt]
\textbf{Verdict: RAG is technically impossible on ship hardware.}\\
\textbf{Knowledge must live entirely in model weights.}
\end{dangerblock}
\end{columns}
\end{frame}

